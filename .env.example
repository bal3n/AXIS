# Required: create a Notion internal integration, invite it to the three pages, and paste the token here.
NOTION_TOKEN=secret_xxx

# Defaults are the Axis pages from the current request. Override if pages move.
NOTION_ROBOTICS_ROOT_PAGE_ID=35c68db0a61c80fcade6c0b5e9ae0633
NOTION_MENGFEI_PAGE_ID=2df68db0a61c80c2b820ec5706e5750b
NOTION_YIKAI_PAGE_ID=30168db0a61c80a690e8cb41c24ade6b
UPDATE_YEAR=2026

# For a static site, keep this true so videos/images are copied into public/media/notion.
# For private Vercel server deployments, you can set this false and serve fresh Notion URLs at request/build time.
NOTION_DOWNLOAD_MEDIA=true

# Optional Basic Auth. Leave blank to disable. Strongly recommended before deploying internal work publicly.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
